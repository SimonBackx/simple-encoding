{
    "name": "@simonbackx/simple-encoding",
    "version": "2.26.0",
    "type": "module",
    "main": "./dist/cjs/index.js",
    "module": "./dist/esm/index.js",
    "types": "./dist/esm/index.d.ts",
    "exports": {
        ".": {
            "import": "./dist/esm/index.js",
            "require": "./dist/cjs/index.js",
            "types": "./dist/esm/index.d.ts"
        }
    },
    "sideEffects": false,
    "scripts": {
        "build": "tsc --build tsconfig.cjs.json tsconfig.esm.json && echo '{\"type\":\"commonjs\"}' > dist/cjs/package.json",
        "lint": "eslint",
        "test": "NODE_OPTIONS=\"--max-old-space-size=8192 --max-semi-space-size=1024\" jest",
        "prepublishOnly": "pnpm build"
    },
    "files": [
        "dist",
        "esm/dist",
        "esm/package.json"
    ],
    "peerDependencies": {
        "@simonbackx/simple-errors": "^1.5.0",
        "tslib": "^2.8.1"
    },
    "devDependencies": {
        "@simonbackx/simple-encoding": "workspace:*",
        "@simonbackx/simple-errors": "^1.5.0",
        "@types/jest": "^26.0.20",
        "@types/node": "^25.5.0",
        "@types/uuid": "^9.0.0",
        "eslint": "^9",
        "eslint-plugin-stamhoofd": "^2.119.0",
        "jest": "^30.3.0",
        "ts-jest": "^29.4.6",
        "tslib": "^2.8.1",
        "typescript": "^5.9.3",
        "uuid": "^9.0.0"
    },
    "resolutions": {
        "uuid": "^9.0.0"
    },
    "packageManager": "pnpm@10.32.1+sha512.a706938f0e89ac1456b6563eab4edf1d1faf3368d1191fc5c59790e96dc918e4456ab2e67d613de1043d2e8c81f87303e6b40d4ffeca9df15ef1ad567348f2be"
}
