{
    "name": "@simonbackx/simple-encoding",
    "version": "2.25.0",
    "type": "module",
    "main": "./dist/cjs/index.js",
    "module": "./dist/esm/index.js",
    "types": "./dist/esm/index.d.ts",
    "exports": {
        ".": {
            "import": "./dist/esm/index.js",
            "require": "./dist/cjs/index.js",
            "types": "./dist/esm/index.d.ts"
        }
    },
    "sideEffects": false,
    "scripts": {
        "build": "tsc --build tsconfig.cjs.json tsconfig.esm.json && echo '{\"type\":\"commonjs\"}' > dist/cjs/package.json",
        "lint": "eslint",
        "test": "NODE_OPTIONS=\"--max-old-space-size=8192 --max-semi-space-size=1024\" jest",
        "postinstall": "rm -rf node_modules/@simonbackx/simple-encoding"
    },
    "files": [
        "dist",
        "esm/dist",
        "esm/package.json"
    ],
    "peerDependencies": {
        "@simonbackx/simple-errors": "^1.5.0",
        "tslib": "^2.8.1"
    },
    "devDependencies": {
        "@eslint/js": "^9.11.1",
        "@simonbackx/simple-encoding": "file:.",
        "@simonbackx/simple-errors": "^1.5.0",
        "@types/jest": "^26.0.20",
        "@types/node": "^25.5.0",
        "@types/uuid": "^9.0.0",
        "eslint": "^9",
        "eslint-plugin-stamhoofd": "^2.119.0",
        "jest": "^30.3.0",
        "ts-jest": "^29.4.6",
        "tslib": "^2.8.1",
        "typescript": "^5.9.3",
        "uuid": "^9.0.0"
    },
    "resolutions": {
        "uuid": "^9.0.0"
    }
}
