{
    "name": "@simonbackx/simple-encoding",
    "main": "./dist/index.js",
    "module": "./esm/dist/index.js",
    "types": "./dist/index.d.ts",
    "version": "2.24.0",
    "sideEffects": false,
    "type": "commonjs",
    "exports": {
        ".": {
            "import": "./esm/dist/index.mjs",
            "require": "./dist/index.js",
            "types": "./dist/index.d.ts"
        }
    },
    "scripts": {
        "build": "yarn build-cjs && yarn build-esm",
        "build-cjs": "tsc -p . --declaration",
        "build-esm": "tsc -p esm --declaration && mv esm/dist/index.js esm/dist/index.mjs",
        "lint": "eslint",
        "test": "NODE_OPTIONS=\"--max-old-space-size=8192 --max-semi-space-size=1024\" jest",
        "postinstall": "rm -rf node_modules/@simonbackx/simple-encoding"
    },
    "files": [
        "dist",
        "esm/dist",
        "esm/package.json"
    ],
    "peerDependencies": {
        "@simonbackx/simple-errors": "^1.5.0",
        "tslib": "^2.8.1"
    },
    "devDependencies": {
        "@eslint/js": "^9.11.1",
        "@simonbackx/simple-encoding": "file:.",
        "@simonbackx/simple-errors": "^1.5.0",
        "@types/jest": "^26.0.20",
        "@types/node": "^25.5.0",
        "@types/uuid": "^9.0.0",
        "eslint": "^9.11.1",
        "eslint-plugin-stamhoofd": "^2.74.0",
        "jest": "^30.3.0",
        "ts-jest": "^29.4.6",
        "tslib": "^2.8.1",
        "typescript": "^5.9.3",
        "uuid": "^9.0.0"
    },
    "resolutions": {
        "uuid": "^9.0.0"
    }
}
