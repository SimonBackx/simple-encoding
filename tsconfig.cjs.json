{
    // File used when building the package.
    "extends": "./tsconfig.base.json",
    "compilerOptions": {
        "outDir": "./dist/cjs"
    },
    "include": [
        "./index.ts",
        "./src/**/*.ts",
    ],
    "exclude": [
        // Tests are excluded (only included in tsconfig.test.json)
        "src/**/*.spec.ts",
        "src/**/*.test.ts"
    ]
}