{
    "compilerOptions": {
        "target": "es2022",
        "module": "commonjs",
        "jsx": "preserve",
        "importHelpers": true,
        "moduleResolution": "node",
        "experimentalDecorators": true,
        "esModuleInterop": true,
        "allowSyntheticDefaultImports": true,
        "sourceMap": true,
        "strictNullChecks": true,
        "outDir": "dist/",
        "lib": ["esnext", "dom", "dom.iterable", "scripthost"],
        "types": ["node", "jest"],
        "alwaysStrict": true,
        "skipLibCheck": false,
        "paths": {
            // Fixed for self referencing
            "@simonbackx/simple-encoding": ["./index.ts"],
            "@simonbackx/simple-encoding/*.ts": ["./src/*.ts"],
            "@simonbackx/simple-encoding/*": ["./src/*"],
        }
    },
    "include": [
        "index.ts",
        "src/*.ts",
        "src/**/*.ts",
        "*.d.ts" // Include vue type definition for webpack
    ],
    "exclude": [
        "node_modules",
        "dist",
        "esm/dist",
        "dist/**/*"
    ]
}
