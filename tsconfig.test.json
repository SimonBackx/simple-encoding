{
    // File used when building the package.
    "extends": "./tsconfig.base.json",
    "compilerOptions": {
        "module": "nodenext",
        "moduleResolution": "nodenext",
        "outDir": "./dist/test",
        "lib": [
            "es2022",
            "dom"
        ],
        "types": [
            "node",
            "vitest/globals"
        ]
    },
    "references": [
        // Give access to build
        {
            "path": "./tsconfig.esm.json"
        }
    ],
    "include": [
        "./src/**/*.spec.ts",
        "./src/**/*.test.ts",
        "./tests",
    ]
}